{
  "name": "agent-hodl",
  "version": "0.3.0",
  "type": "module",
  "license": "MIT",
  "author": "Michal Sek (https://github.com/michalsek)",
  "homepage": "https://github.com/michalsek/hodl",
  "keywords": [
    "ai",
    "agent",
    "orchestration",
    "workflow",
    "codex",
    "claude",
    "lock",
    "concurrency",
    "coordination",
    "vscode",
    "LLM"
  ],
  "description": "Machine-wide local file lock daemon for lease-based coordination on macOS.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michalsek/hodl.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./protocol": {
      "types": "./dist/protocol/index.d.ts",
      "default": "./dist/protocol/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "bin": {
    "agent-hodl": "./dist/cli/Hodl.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/cli/Hodl.ts",
    "dev": "tsx watch src/cli/Hodl.ts",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run test && npm pack --dry-run",
    "publish:npm": "npm publish",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run src/tests"
  },
  "dependencies": {
    "ink": "^6.8.0",
    "react": "^19.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "@types/react": "^19.2.14",
    "tsx": "^4.20.6",
    "typescript": "~5.9.2",
    "vitest": "^3.2.4"
  }
}
