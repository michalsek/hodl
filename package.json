{
  "name": "hodl",
  "version": "0.1.0",
  "type": "module",
  "description": "Machine-wide local file lock daemon for lease-based coordination on macOS.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michalsek/hodl.git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./protocol": {
      "types": "./dist/protocol/index.d.ts",
      "default": "./dist/protocol/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "bin": {
    "hodl": "./dist/cli/Hodl.js",
    "hodlctl": "./dist/cli/Hodlctl.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/CopyDashboardPage.mjs",
    "start": "tsx src/cli/Hodl.ts",
    "dev": "tsx watch src/cli/Hodl.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run src/tests"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "tsx": "^4.20.6",
    "typescript": "~5.9.2",
    "vitest": "^3.2.4"
  }
}
